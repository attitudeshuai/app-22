{
  "info": {
    "name": "雨伞借还点系统 API 测试集合",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "UmbrellaPoint 共享雨伞借还管理平台完整 API 测试集合"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8092" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "01-Auth 认证",
      "item": [
        {
          "name": "1.1 用户登录 - admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('状态码为200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('登录成功', () => pm.expect(json.code).to.eql(200));",
                  "pm.test('Token存在', () => pm.expect(json.data.token).to.exist);",
                  "pm.collectionVariables.set('token', json.data.token);",
                  "pm.collectionVariables.set('userId', json.data.user.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\"usernameOrEmail\":\"admin\",\"password\":\"123456\"}"
            }
          }
        },
        {
          "name": "1.2 获取当前用户信息",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('状态码为200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('获取成功', () => pm.expect(json.code).to.eql(200));",
                  "pm.test('用户名正确', () => pm.expect(json.data.username).to.eql('admin'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/auth/me"
          }
        },
        {
          "name": "1.3 更新个人信息",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('状态码为200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('更新成功', () => pm.expect(json.code).to.eql(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/auth/me",
            "body": {
              "mode": "raw",
              "raw": "{\"avatar\":\"https://example.com/avatar.png\"}"
            }
          }
        },
        {
          "name": "1.4 未登录访问受限接口 - 应返回401",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('状态码为401/403', () => pm.response.to.have.status.oneOf([401, 403]));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/stations"
          }
        }
      ]
    },
